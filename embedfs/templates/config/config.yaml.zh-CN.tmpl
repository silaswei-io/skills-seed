########################################################################
# 基础信息
# 当前配置文件所属项目或工作区的身份信息
########################################################################
profile:
  # 项目名称，init 时自动填充
  name: ""
  # 初始化模式：project 单项目，workspace 多子项目工作区；开始学习或生成后不可切换
  mode: "project"
  # 项目主要语言，init 时自动识别；识别不到时留空
  language: ""
  # 工具输出语言：zh-CN 中文，en-US 英文
  locale: "zh-CN"
  # Git 远程仓库地址，init 时自动填充
  git_remote: ""
  # 项目根目录绝对路径，init 时自动填充
  root_path: ""
  # 项目初始化时间，init 时自动填充
  initialized_at: ""

########################################################################
# 工作区
# 仅 workspace 模式生效，普通 project 子仓通常不需要配置
########################################################################
workspace:
  # 子项目列表，例如 [{id: "project-a", path: "project-a", type: "application", language: "primary-language"}]
  projects: []

########################################################################
# Agent 引擎
# 控制学习、检查和生成任务使用的 Agent 引擎与并发策略
########################################################################
agent:
  # 执行分析/学习/生成摘要任务的 Agent 引擎，对应 commands 的 key
  engine: "claude"
  # Agent 引擎到本机 CLI 命令的映射；仅控制如何调用分析 Agent
  commands:
    claude: "claude"
    codex: "codex"
  # AI 请求超时时间(秒)
  timeout: 1800
  # 是否允许 Agent 加载用户插件；默认关闭以避免批处理被插件干扰
  allow_user_plugins: false
  # 工作区子项目并发数；仅 workspace 根配置生效，0 表示自动
  parallelism: 0
  # 可重试错误，如 429、529 过载等的重试配置
  retry:
    # 最大重试次数，0 使用默认值 3
    max_retries: 3
    # 首次重试等待秒数
    initial_interval: 15
    # 最大等待秒数（指数退避上限）
    max_interval: 120

########################################################################
# 学习
# 控制 learn current 和 learn history 的默认学习范围
########################################################################
learning:
  current:
    # 学习模式：fast 更快，normal 默认平衡，deep 更深入
    mode: "normal"
    # 分析单元切分范围：domain 按业务域合并，flow 按流程拆分，module 按模块/插件更细拆分
    scope: "flow"
    # 项目内分析单元并发数；普通项目或 workspace 子项目生效，1 表示串行
    parallelism: 1
    # 单次 AI 调用最多分析的单元数；1 表示不合批，降低单次输出过大和跨单元串扰风险
    max_units_per_call: 1
    # 启用相关文件筛选，先基于候选文件树收敛 learn current 的分析范围
    select_relevant_files: true
    # 候选文件数达到该阈值时才调用 AI 文件筛选；小项目直接使用本地过滤结果
    select_relevant_files_min_candidates: 200
    budget:
      # 单个分析单元最多入库的候选模式数；0 表示不限制
      max_patterns_per_unit: 3
      # 单次 learn current 最多入库的候选模式数；0 表示不限制
      max_patterns_per_run: 12
      # 极小改动最多新增模式数；0 表示只审计旧模式，不新增
      micro_change_new_patterns: 0
      # 小改动最多新增模式数
      minor_change_new_patterns: 3
      # 低于该置信度的候选默认不入库
      min_confidence: 0.78
      # 小改动优先更新已有模式，避免新增碎片模式
      update_existing_first: true
      # 候选必须包含可路由源码证据位置
      require_routeable_evidence: true
    structural:
      # 启用有边界的结构化上下文；无边界输入时不会运行
      enabled: true
      # 输出到结构化上下文的最大符号数
      max_symbols: 30
      # 跳过超过此大小的单个文件（KB）
      max_file_size: 512
  history:
    # 默认分析的 Git 提交数量
    max_commits: 50
    # 批量分析时，单次 AI 调用分析的 commit 数量
    batch_size: 5

########################################################################
# 自动修复
# 控制 check --fix 的修复产物和回滚策略
########################################################################
autofix:
  # 修复策略：patch 生成 .patch 文件，backup 备份原文件后修改，stash 应用修复后 git stash，branch 创建新分支应用修复
  strategy: "patch"
  # 备份路径，相对于 .skills-seed 目录
  backup_path: "backups"

########################################################################
# Skills 生成
# 控制生成的 Skills 目标类型、输出路径和内容语言
########################################################################
skills:
  # 生成的 Skills 目标类型；可与 agent.engine 不同，例如用 claude 生成 codex skills
  target: "claude"
  # 生成的 Skills、AI prompt 和沉淀到 Skills 的自然语言内容：zh-CN 中文，en-US 英文
  locale: "en-US"
  # Skills 目标类型到输出目录的映射；仅控制生成产物保存位置
  paths:
    claude: ".claude/skills/skills-seed-skills"
    codex: ".agents/skills/skills-seed-skills"

########################################################################
# 日志
# 控制命令运行日志的级别、路径和保留数量
########################################################################
logging:
  # 日志级别: DEBUG, INFO, WARN, ERROR
  level: "DEBUG"
  # 日志路径，相对于 .skills-seed 目录
  logs_path: "runtime/logs"
  # 日志文件最大数量(自动清理旧日志)
  max_log_files: 30

########################################################################
# 全局排除
# 控制学习、预览、结构化分析等命令共享的文件边界
########################################################################
exclude:
  # 是否排除 Git ignore 命中的文件
  gitignore: true
  # 需要排除的相对路径或 glob；初始化时写入默认静态排除规则
  paths:
    # 点号开头的文件和目录，如 .github、.cursor、.env
    - ".*"
    # 常见依赖目录
    - "vendor/**"
    # 常见依赖目录
    - "node_modules/**"
    # 常见构建产物目录
    - "dist/**"
    # 常见构建产物目录
    - "build/**"
    # 常见输出目录
    - "out/**"
    # 常见构建产物目录
    - "target/**"
    # 覆盖率报告目录
    - "coverage/**"
    # 缓存目录
    - ".cache/**"
    # 临时目录
    - "tmp/**"
    # 临时目录
    - "temp/**"
    # 日志文件
    - "*.log"
    # 临时文件
    - "*.tmp"
    # 备份文件
    - "*.bak"
    # 编辑器交换文件
    - "*.swp"
    # 压缩包
    - "*.zip"
    # 压缩包
    - "*.tar"
    # 压缩包
    - "*.tar.gz"
    # 压缩包
    - "*.tgz"
    # 压缩包
    - "*.rar"
    # 压缩包
    - "*.7z"
    # 图片资源
    - "*.png"
    # 图片资源
    - "*.jpg"
    # 图片资源
    - "*.jpeg"
    # 图片资源
    - "*.gif"
    # 图片资源
    - "*.webp"
    # 图标资源
    - "*.ico"
    # 文档产物
    - "*.pdf"
    # 视频资源
    - "*.mp4"
    # 视频资源
    - "*.mov"
