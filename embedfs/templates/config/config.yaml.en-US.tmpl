########################################################################
# Profile
# Identity for the project or workspace described by this config file
########################################################################
profile:
  # Project name (auto-filled during init)
  name: ""
  # Init mode: project (single project) or workspace (multi-project workspace). Locked after learning or generation starts
  mode: "project"
  # Primary language, for example go, typescript, python
  language: "go"
  # CLI output language: zh-CN (Chinese) or en-US (English)
  locale: "en-US"
  # Git remote repository URL (auto-filled during init)
  git_remote: ""
  # Project root directory absolute path (auto-filled during init)
  root_path: ""
  # Project initialization time (auto-filled during init)
  initialized_at: ""

########################################################################
# Workspace
# Only used in workspace mode, ordinary project child repositories usually do not need this
########################################################################
workspace:
  # Child projects, for example: [{id: "frontend", path: "frontend", type: "frontend", language: "typescript"}]
  projects: []

########################################################################
# Analysis
# Controls structured code analysis, omitted fields use defaults
########################################################################
analysis:
  codegraph:
    # Enable CodeGraph structural analysis by default; warn and fall back when unavailable
    enabled: true
    # true fails when CodeGraph is unavailable; false continues with normal analysis
    required: false
    # codegraph command path
    command: "codegraph"
    # Run codegraph init -i automatically when the target project has no .codegraph
    auto_init: true
    # Run codegraph sync before analysis when an index exists
    auto_sync: true
    # Maximum symbol nodes for codegraph context
    max_nodes: 30
    # Maximum code blocks for codegraph context; 0 means structural summary only
    max_code: 0

########################################################################
# Agent
# Controls the Agent engine and concurrency used by learning, checking, and generation
########################################################################
agent:
  # Agent engine used for analysis, learning, and generation summaries; matches keys in commands
  engine: "claude"
  # engine -> CLI command path; add new engines here
  commands:
    claude: "claude"
    codex: "codex"
  # AI request timeout (seconds)
  timeout: 1800
  # Whether agents may load user plugins; disabled by default for batch stability
  allow_user_plugins: false
  # Number of concurrent agents; 0 means automatic (project=1, workspace=project count with cap)
  parallelism: 0
  # Retry configuration for retryable errors such as 429 and 529 overloaded
  retry:
    # Maximum retry attempts; 0 uses default (3)
    max_retries: 3
    # Initial retry wait in seconds
    initial_interval: 15
    # Maximum wait in seconds (exponential backoff cap)
    max_interval: 120

########################################################################
# Learning
# Controls the default range for learning project rules from Git history
########################################################################
learning:
  # Default number of Git commits to analyze
  max_commits: 50
  # Number of commits to analyze per AI call in batch mode
  batch_size: 5

########################################################################
# Auto-Fix
# Controls the output and rollback strategy for check --fix
########################################################################
autofix:
  # Fix strategy: patch: Generate .patch files (recommended, safe); backup: Backup files before modification; stash: Apply fixes then git stash; branch: Create new branch to apply fixes
  strategy: "patch"
  # Backup path (relative to .skills-seed directory)
  backup_path: "backups"

########################################################################
# Skills
# Controls the generated Skills target type and output paths
########################################################################
skills:
  # Target Skills type; can differ from agent.engine, for example use claude to generate codex skills
  target: "claude"
  # target -> Skills output path; add new targets here
  paths:
    claude: ".claude/skills/skills-seed-skills"
    codex: ".agents/skills/skills-seed-skills"

########################################################################
# Logging
# Controls command log level, path, and retention
########################################################################
logging:
  # Log level: DEBUG, INFO, WARN, ERROR
  level: "DEBUG"
  # Log path (relative to .skills-seed directory)
  logs_path: "logs"
  # Maximum number of log files (auto-cleanup)
  max_log_files: 30

########################################################################
# Global Exclusions
# Glob-style patterns (not regex); init writes the default static exclusion rules
########################################################################
exclude:
  # Dot-prefixed files and directories, such as .github, .cursor, .codegraph, .env
  - ".*"
  # Common dependency directory
  - "vendor/**"
  # Common dependency directory
  - "node_modules/**"
  # Common build output directory
  - "dist/**"
  # Common build output directory
  - "build/**"
  # Common output directory
  - "out/**"
  # Common build output directory
  - "target/**"
  # Coverage report directory
  - "coverage/**"
  # Cache directory
  - ".cache/**"
  # Temporary directory
  - "tmp/**"
  # Temporary directory
  - "temp/**"
  # Log files
  - "*.log"
  # Temporary files
  - "*.tmp"
  # Backup files
  - "*.bak"
  # Editor swap files
  - "*.swp"
  # Archives
  - "*.zip"
  # Archives
  - "*.tar"
  # Archives
  - "*.tar.gz"
  # Archives
  - "*.tgz"
  # Archives
  - "*.rar"
  # Archives
  - "*.7z"
  # Image assets
  - "*.png"
  # Image assets
  - "*.jpg"
  # Image assets
  - "*.jpeg"
  # Image assets
  - "*.gif"
  # Image assets
  - "*.webp"
  # Icon assets
  - "*.ico"
  # Document artifacts
  - "*.pdf"
  # Video assets
  - "*.mp4"
  # Video assets
  - "*.mov"
