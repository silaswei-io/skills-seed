########################################################################
# Profile
# Identity for the project or workspace described by this config file
########################################################################
profile:
  # Project name (auto-filled during init)
  name: ""
  # Init mode: project (single project) or workspace (multi-project workspace). Locked after learning or generation starts
  mode: "project"
  # Primary language, auto-detected during init; empty when unknown
  language: ""
  # Tool output language: zh-CN (Chinese) or en-US (English)
  locale: "en-US"
  # Git remote repository URL (auto-filled during init)
  git_remote: ""
  # Project root directory absolute path (auto-filled during init)
  root_path: ""
  # Project initialization time (auto-filled during init)
  initialized_at: ""

########################################################################
# Workspace
# Only used in workspace mode, ordinary project child repositories usually do not need this
########################################################################
workspace:
  # Child projects, for example: [{id: "project-a", path: "project-a", type: "application", language: "primary-language"}]
  projects: []

########################################################################
# Agent
# Controls the Agent engine and concurrency used by learning, checking, and generation
########################################################################
agent:
  # Agent engine used for analysis, learning, and generation summaries; matches keys in commands
  engine: "claude"
  # Mapping from Agent engine to local CLI command; only controls how analysis agents are invoked
  commands:
    claude: "claude"
    codex: "codex"
  # AI request timeout (seconds)
  timeout: 1800
  # Whether agents may load user plugins; disabled by default for batch stability
  allow_user_plugins: false
  # Number of concurrent agents; 0 means automatic (project=1, workspace=project count with cap)
  parallelism: 0
  # Retry configuration for retryable errors such as 429 and 529 overloaded
  retry:
    # Maximum retry attempts; 0 uses default (3)
    max_retries: 3
    # Initial retry wait in seconds
    initial_interval: 15
    # Maximum wait in seconds (exponential backoff cap)
    max_interval: 120

########################################################################
# Learning
# Controls the default scope for learn current and learn history
########################################################################
learning:
  current:
    # Enable relevant-file selection to narrow learn current scope from the candidate file tree
    select_relevant_files: true
    # Only call AI file selection when candidate files reach this threshold; smaller projects use local filtering
    select_relevant_files_min_candidates: 200
    structural:
      # Enable bounded structural context; it does not run without bounded inputs
      enabled: true
      # Maximum symbols emitted into structural context
      max_symbols: 30
      # Skip individual files larger than this size (KB)
      max_file_size: 512
  history:
    # Default number of Git commits to analyze
    max_commits: 50
    # Number of commits to analyze per AI call in batch mode
    batch_size: 5

########################################################################
# Auto-Fix
# Controls the output and rollback strategy for check --fix
########################################################################
autofix:
  # Fix strategy: patch: Generate .patch files (recommended, safe); backup: Backup files before modification; stash: Apply fixes then git stash; branch: Create new branch to apply fixes
  strategy: "patch"
  # Backup path (relative to .skills-seed directory)
  backup_path: "backups"

########################################################################
# Skills
# Controls the generated Skills target type, output paths, and content language
########################################################################
skills:
  # Target Skills type; can differ from agent.engine, for example use claude to generate codex skills
  target: "claude"
  # Generated Skills, AI prompts, and natural-language content persisted into Skills: zh-CN (Chinese) or en-US (English)
  locale: "en-US"
  # Mapping from Skills target type to output directory; only controls where generated artifacts are saved
  paths:
    claude: ".claude/skills/skills-seed-skills"
    codex: ".agents/skills/skills-seed-skills"

########################################################################
# Logging
# Controls command log level, path, and retention
########################################################################
logging:
  # Log level: DEBUG, INFO, WARN, ERROR
  level: "DEBUG"
  # Log path (relative to .skills-seed directory)
  logs_path: "runtime/logs"
  # Maximum number of log files (auto-cleanup)
  max_log_files: 30

########################################################################
# Global Exclusions
# Controls file boundaries shared by learning, preview, and structural analysis
########################################################################
exclude:
  # Whether to exclude files matched by Git ignore rules
  gitignore: true
  # Relative paths or globs to exclude; init writes the default static exclusion rules
  paths:
    # Dot-prefixed files and directories, such as .github, .cursor, .env
    - ".*"
    # Common dependency directory
    - "vendor/**"
    # Common dependency directory
    - "node_modules/**"
    # Common build output directory
    - "dist/**"
    # Common build output directory
    - "build/**"
    # Common output directory
    - "out/**"
    # Common build output directory
    - "target/**"
    # Coverage report directory
    - "coverage/**"
    # Cache directory
    - ".cache/**"
    # Temporary directory
    - "tmp/**"
    # Temporary directory
    - "temp/**"
    # Log files
    - "*.log"
    # Temporary files
    - "*.tmp"
    # Backup files
    - "*.bak"
    # Editor swap files
    - "*.swp"
    # Archives
    - "*.zip"
    # Archives
    - "*.tar"
    # Archives
    - "*.tar.gz"
    # Archives
    - "*.tgz"
    # Archives
    - "*.rar"
    # Archives
    - "*.7z"
    # Image assets
    - "*.png"
    # Image assets
    - "*.jpg"
    # Image assets
    - "*.jpeg"
    # Image assets
    - "*.gif"
    # Image assets
    - "*.webp"
    # Icon assets
    - "*.ico"
    # Document artifacts
    - "*.pdf"
    # Video assets
    - "*.mp4"
    # Video assets
    - "*.mov"
