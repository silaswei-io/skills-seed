  "framework_patterns": ["Concrete framework usage pattern"],
  "structure": "Concrete project structure summary",
  "key_modules": [
    {
      "name": "Module name",
      "path": "module/path",
      "description": "Module role",
      "responsibilities": ["Specific responsibility"],
      "dependencies": ["dependency module"],
      "dependents": ["dependent module"],
      "key_methods": ["Important method signature"]
    }
  ],
  "business_methods": [
    {
      "name": "MethodName",
      "location": "file/path.go:line",
      "description": "Business logic description",
      "usage": "When to call this method",
      "type": "domain|common",
      "function": "Full method signature",
      "prerequisites": "Required setup or dependencies",
      "returns": "Return values and possible errors"
    }
  ],
  "common_utils": [
    {
      "name": "FunctionName",
      "file": "file/path.go",
      "signature": "func FunctionName(...) ...",
