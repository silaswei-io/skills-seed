      "good_example": "从输入中选择的真实代码示例",
      "bad_example": "从输入中选择的反例，没有则为空",
      "rule": "当 X 时，应该 Y",
      "confidence": 0.86,
      "frequency": 3,
      "merged_from": ["existing-id", "candidate-id"],
      "merge_reason": "新增、更新或合并的原因",
      "similarity_score": 0.9,
      "source": "learned_current",
      "business_method": {
        "name": "真实方法名或签名",
        "code_location": {"current_location": "文件路径:行号"},
        "description": "真实描述",
        "usage": "真实使用场景",
        "type": "domain|common",
        "function": "真实函数签名",
        "prerequisites": "真实前置条件",
        "returns": "真实返回说明"
      },
      "project_id": "workspace-project-id",
      "scope_path": "relative/scope",
      "workspace_role": "project-role"
    }
